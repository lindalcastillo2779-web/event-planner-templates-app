import 'package:flutter_test/flutter_test.dart';
import 'package:events_app/models/event.dart';

void main() {
  final base = Event(
    id: 'abc',
    name: 'Sofía & Miguel',
    eventType: EventType.wedding,
    tradition: Tradition.catholic,
    date: DateTime(2027, 6, 14),
    venueName: 'San Fernando Cathedral',
    guestCountTarget: 150,
    createdAt: DateTime(2026, 7, 12),
    updatedAt: DateTime(2026, 7, 12),
  );

  group('Event model', () {
    test('copyWith updates fields and keeps id/createdAt', () {
      final edited = base.copyWith(name: 'Sofía · XV');
      expect(edited.id, base.id);
      expect(edited.createdAt, base.createdAt);
      expect(edited.name, 'Sofía · XV');
      expect(edited.eventType, EventType.wedding);
    });

    test('copyWith can clear nullable fields', () {
      final cleared = base.copyWith(clearDate: true, clearVenue: true);
      expect(cleared.date, isNull);
      expect(cleared.venueName, isNull);
    });

    test('plannedFraction counts filled planning fields', () {
      expect(base.plannedFraction, 1.0); // date + venue + guests
      final bare = base.copyWith(
          clearDate: true, clearVenue: true, clearGuestCount: true);
      expect(bare.plannedFraction, 0.0);
      final partial = base.copyWith(clearVenue: true, clearGuestCount: true);
      expect(partial.plannedFraction, closeTo(1 / 3, 0.001));
    });

    test('linked ids round-trip through JSON encoding', () {
      const ids = ['a', 'b', 'c'];
      final raw = Event.encodeLinkedIds(ids);
      expect(Event.decodeLinkedIds(raw), ids);
      expect(Event.decodeLinkedIds(''), isEmpty);
    });
  });
}
